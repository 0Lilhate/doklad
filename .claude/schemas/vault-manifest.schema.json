{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://obsidian-mind/vault-manifest.schema.json",
  "title": "Vault Manifest",
  "description": "Schema for vault-manifest.json. Validates structure of obsidian-mind vault metadata.",
  "type": "object",
  "required": [
    "claude_mind_version",
    "vault_name",
    "qmd_index",
    "allowed_type_values",
    "allowed_status_values",
    "frontmatter_required",
    "infrastructure",
    "user_content_roots"
  ],
  "properties": {
    "claude_mind_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver of obsidian-mind methodology version"
    },
    "vault_name": {
      "type": "string",
      "minLength": 1
    },
    "created": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "qmd_index": {
      "type": "string",
      "minLength": 1,
      "description": "Name of qmd collection for this vault"
    },
    "qmd_context": {
      "type": "string"
    },
    "languages": {
      "type": "array",
      "items": { "type": "string", "minLength": 2, "maxLength": 5 },
      "minItems": 1
    },
    "language_mode": {
      "type": "string",
      "enum": ["english-only", "russian-only", "bilingual-pragmatic", "bilingual-strict"]
    },
    "naming_convention": {
      "type": "object",
      "properties": {
        "durable_folders": { "type": "string" },
        "archive_folders": { "type": "string" },
        "temporal_files": { "type": "string" },
        "filename_charset": { "type": "array", "items": { "type": "string" } }
      }
    },
    "allowed_type_values": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
      "minItems": 1,
      "uniqueItems": true
    },
    "allowed_status_values": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
      "minItems": 1,
      "uniqueItems": true
    },
    "frontmatter_required": {
      "type": "object",
      "required": ["default"],
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "field_aliases": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "infrastructure": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scaffold": {
      "type": "array",
      "items": { "type": "string" }
    },
    "user_content_roots": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "bilingual": {
      "type": "object",
      "properties": {
        "mode": { "type": "string" },
        "key_categories_require_bilingual_aliases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "transliteration_for_filenames": {
          "type": "string",
          "enum": ["required", "optional", "forbidden"]
        }
      }
    },
    "decision_points_resolved": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "roadmap": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
