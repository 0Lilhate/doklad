{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",
    "ECC_HOOK_PROFILE": "minimal"
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(node --experimental-strip-types .claude/scripts/*)",
      "Bash(node --version)",
      "Bash(python3 .claude/scripts/*)",
      "Bash(python3 --version)",
      "Bash(bash .claude/scripts/*)",
      "Bash(bash .claude/bin/*)",
      "Bash(jq:*)",
      "Bash(git tag:*)",
      "Bash(dir *)",
      "Read(/c/Program Files/**)",
      "Read(//tmp/**)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:opencode.ai)",
      "WebSearch",
      "WebFetch(domain:deepwiki.com)",
      "WebFetch(domain:blog.iamcristhian.dev)",
      "WebFetch(domain:www.nxcode.io)",
      "Bash(where mcp-atlassian *)",
      "Bash(mcp-atlassian --version)",
      "mcp__mcp-atlassian__confluence_search",
      "mcp__mcp-atlassian__confluence_get_page",
      "Bash(qmd --help)",
      "Bash(xargs -I {} basename {})",
      "Bash(echo \"EXIT: $?\")",
      "Bash(echo \"---EXIT: $?\")",
      "Bash(curl -L --fail --silent --show-error -o /usr/bin/jq.exe https://github.com/jqlang/jq/releases/latest/download/jq-windows-amd64.exe)",
      "Read(//usr/bin/**)",
      "Bash(cp __TRACKED_VAR__/bin/jq.exe '/c/Program Files/Git/usr/bin/jq.exe')",
      "Read(//c/Program Files/Git/usr/bin/**)",
      "Bash(xargs -I{} echo \"subsections: {}\")",
      "Bash(defuddle parse *)",
      "WebFetch(domain:cursor.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:www.builder.io)",
      "WebFetch(domain:arxiv.org)",
      "Bash(python -c \"import markdown; print\\(markdown.__version__\\)\")",
      "Bash(python -c \"import markdown_it; print\\('markdown_it OK'\\)\")",
      "Bash(pip install *)",
      "Bash(python .tmp_md_to_html.py)"
    ],
    "deny": [
      "Bash(cmd.exe *)",
      "Bash(powershell *)",
      "Bash(rm -rf *)",
      "Bash(obsidian eval *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "memory",
    "sequential-thinking",
    "context7",
    "playwright"
  ]
}
