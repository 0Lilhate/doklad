{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/bin/claude-block-sensitive-bash.sh"
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/bin/claude-block-sensitive-files.sh"
          }
        ]
      }
    ]
  }
}
