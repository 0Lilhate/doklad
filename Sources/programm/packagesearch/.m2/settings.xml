<?xml version="1.0" encoding="UTF-8"?>

<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0 
          https://maven.apache.org/xsd/settings-1.2.0.xsd">
  
  <!-- Credentials для Artifactory -->
  <servers>
    <server>
      <id>central-local</id>
      <!-- <username>admin</username> -->
      <!-- <password>password</password> -->
    </server>
  </servers>

  <!-- Зеркало для репозитория central-local -->
  <mirrors>
    <mirror>
      <id>maven-default-http-blocker</id>
      <mirrorOf>central-local</mirrorOf>
      <name>Pseudo repository to mirror external repositories initially using HTTP.</name>
      <url>http://nas.it-alnc.ru:8081/artifactory/libs-snapshot-local</url>
      <blocked>false</blocked>
    </mirror>
  </mirrors>

  <profiles>
    <profile>
      <id>corporate-artifactory</id>
      
      <!-- Репозитории для зависимостей -->
      <repositories>
        <repository>
          <id>central-local</id>
          <name>It-Allince-releases</name>
          <url>http://nas.it-alnc.ru:8081/artifactory/libs-snapshot-local</url>
        </repository>
      </repositories>
      
      <!-- Репозитории для плагинов Maven -->
      <pluginRepositories>
        <pluginRepository>
          <id>central-local</id>
          <name>It-Allince-releases</name>
          <url>http://nas.it-alnc.ru:8081/artifactory/libs-snapshot-local</url>
        </pluginRepository>
      </pluginRepositories>
    </profile>
  </profiles>

  <!-- Автоматическая активация профиля -->
  <activeProfiles>
    <activeProfile>corporate-artifactory</activeProfile>
  </activeProfiles>

</settings>
